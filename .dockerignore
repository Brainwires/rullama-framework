# Excludes for any Dockerfile in this workspace. Keep the build context
# lean so docker doesn't have to ship gigabytes of build output to the
# daemon on every `docker build`.

# Rust build output
target/
**/target/

# Node
**/node_modules/
**/npm-debug.log

# Docs-site build dirs
docs/rullama-docs/.next/
docs/rullama-docs/node_modules/

# Git + IDE
.git/
.gitignore
.github/
.vscode/
.idea/
.claude/

# OS noise
.DS_Store
Thumbs.db

# Local dev / test
coverage/
*.log
.env
.env.*
!.env.example

# Docs and changelogs aren't needed in the image
*.md
