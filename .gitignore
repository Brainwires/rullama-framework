**/target/**
Cargo.lock
*.swp
*.swo
.DS_Store
# Legacy: fastembed now stores models in ~/.brainwires/cache/fastembed/
.fastembed_cache/
.cache/.claude/
.mcp.json
CLAUDE_CODE_INTEGRATION.md
.claude/scheduled_tasks.lock

# Secrets — keep `.env.example` templates tracked, ignore everything else.
.env
.env.*
!.env.example

# cargo-fuzz: ignore generated artifacts, keep source + corpus.
fuzz/target/
fuzz/artifacts/
fuzz/Cargo.lock
# Ignore libfuzzer-discovered corpus entries (hex-named hashes); keep the
# human-named seed files (e.g. canonical.json, minimal_card.json) checked in.
fuzz/corpus/**/[0-9a-f]*
