<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AudioDemo.ViewModels"
             x:Class="AudioDemo.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <ScrollViewer Margin="12">
        <ItemsControl ItemsSource="{Binding Providers}">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:ProviderSettingViewModel">
                    <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                            BorderThickness="1" CornerRadius="6"
                            Padding="12" Margin="0,0,0,8">
                        <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto">
                            <!-- Provider name + status -->
                            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding Info.DisplayName}"
                                           FontWeight="Bold" FontSize="14" />
                                <Border Background="{Binding IsConnected, Converter={x:Static BoolConverters.StringConverters.TrueString}}"
                                        CornerRadius="3" Padding="6,2"
                                        IsVisible="{Binding IsConnected}">
                                    <TextBlock Text="Connected" FontSize="11" Foreground="Green" />
                                </Border>
                            </StackPanel>

                            <!-- TTS/STT badges -->
                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                <Border Background="#2196F3" CornerRadius="3" Padding="6,2"
                                        IsVisible="{Binding Info.HasTts}">
                                    <TextBlock Text="TTS" FontSize="11" Foreground="White" />
                                </Border>
                                <Border Background="#4CAF50" CornerRadius="3" Padding="6,2"
                                        IsVisible="{Binding Info.HasStt}">
                                    <TextBlock Text="STT" FontSize="11" Foreground="White" />
                                </Border>
                            </StackPanel>

                            <!-- API Key -->
                            <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,8,0,0">
                                <TextBlock Text="API Key" FontWeight="SemiBold" Margin="0,0,0,4" />
                                <TextBox Text="{Binding ApiKey}"
                                         PasswordChar="*"
                                         Watermark="Enter API key..." />
                            </StackPanel>

                            <!-- Region (Azure only) -->
                            <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0,8,0,0"
                                        IsVisible="{Binding RequiresRegion}">
                                <TextBlock Text="Region" FontWeight="SemiBold" Margin="0,0,0,4" />
                                <TextBox Text="{Binding Region}"
                                         Watermark="e.g. eastus" />
                            </StackPanel>

                            <!-- Test + Status -->
                            <Grid Grid.Row="3" Grid.ColumnSpan="2"
                                  ColumnDefinitions="Auto,*" Margin="0,8,0,0">
                                <Button Grid.Column="0" Content="Test Connection"
                                        Command="{Binding TestConnectionCommand}" />
                                <TextBlock Grid.Column="1" Text="{Binding Status}"
                                           VerticalAlignment="Center" Margin="12,0,0,0"
                                           Opacity="0.7" />
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>

</UserControl>
