{
  "name": "BrainwiresChatNative",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "macos": "react-native run-macos",
    "windows": "react-native run-windows",
    "web": "vite",
    "web:build": "vite build",
    "web:preview": "vite preview",
    "linux": "cd desktop-linux && cargo tauri dev",
    "linux:build": "cd desktop-linux && cargo tauri build",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "bridge:build": "cd bridge && cargo build --release",
    "bridge:bindings:kotlin": "cd bridge && cargo run --bin uniffi-bindgen -- generate --library target/release/libbrainwires_chat_native_bridge.so --language kotlin --out-dir ../android/app/src/main/java",
    "bridge:bindings:swift": "cd bridge && cargo run --bin uniffi-bindgen -- generate --library target/release/libbrainwires_chat_native_bridge.dylib --language swift --out-dir ../ios/generated"
  },
  "dependencies": {
    "@gluestack-ui/nativewind-utils": "^1.0.26",
    "@gluestack-ui/overlay": "^0.1.16",
    "@gluestack-ui/toast": "^1.0.9",
    "@legendapp/motion": "^2.4.0",
    "@react-native/new-app-screen": "0.85.2",
    "nativewind": "^4.1.23",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.2",
    "react-native-reanimated": "^3.16.7",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-svg": "^15.11.2",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "^0.8.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.85.2",
    "@react-native/eslint-config": "0.85.2",
    "@react-native/jest-preset": "0.85.2",
    "@react-native/metro-config": "0.85.2",
    "@react-native/typescript-config": "0.85.2",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "postcss": "^8.5.13",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.4.0"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
