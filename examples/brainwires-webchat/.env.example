# Public URL of the BrainClaw gateway WebSocket endpoint.
# Set this to wherever your gateway is reachable from the browser.
NEXT_PUBLIC_GATEWAY_WS=ws://localhost:18789

# Public URL of the BrainClaw gateway HTTP API (used for history backfill
# and /status requests). Usually the same host as the WS URL.
NEXT_PUBLIC_GATEWAY_HTTP=http://localhost:18789

# HS256 shared secret used to mint browser JWTs.
# Must match `[webchat] jwt_secret` on the gateway side (or the derived
# value when left unset server-side — see the gateway's resolve_webchat_secret).
WEBCHAT_SECRET=changeme

# Admin token that the user exchanges on the /login page to obtain a
# WebChat JWT.  When left blank, any non-empty token is accepted (dev mode).
WEBCHAT_ADMIN_TOKEN=
